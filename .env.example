# =====================
# PRODUCTION DEPLOYMENT
# =====================
# Frontend: Vercel (np. https://music-licensing-platform.vercel.app)
# Backend:  VPS Express.js (np. https://hrl-sync-hub.hardbanrecordslab.online)

# ========== BACKEND .env na VPS ==========
NODE_ENV=production
PORT=9108

# URL frontendu na Vercel – używany przez CORS whitelist
APP_ORIGIN=https://app.hrl-sync-hub.hardbanrecordslab.online

# Wygeneruj: openssl rand -base64 32
JWT_SECRET=replace-with-production-secret
HMAC_SECRET=replace-with-production-secret
HEADLESS_SECRET=replace-with-production-secret

TOKEN_TTL_SECONDS=7200

# ========== FRONTEND – zmienne budowania na Vercel ==========
# Ustaw w: Vercel Dashboard → Project → Settings → Environment Variables
# lub w sekcji build.env w vercel.json (już skonfigurowane)
VITE_API_URL=https://hrl-sync-hub.hardbanrecordslab.online
