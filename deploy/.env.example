# ============================================================
# HRL Backend — Environment Variables for VPS
# Copy to: deploy/.env  (chmod 600 deploy/.env)
# ============================================================

# Required secrets — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-strong-secret
HMAC_SECRET=replace-with-strong-secret
HEADLESS_SECRET=replace-with-strong-secret

# Frontend origin — used for CORS whitelist
APP_ORIGIN=https://app.hrl-sync-hub.hardbanrecordslab.online

# Backend port (default 9108)
PORT=9108

# Token TTL in seconds (default 2h)
TOKEN_TTL_SECONDS=7200
