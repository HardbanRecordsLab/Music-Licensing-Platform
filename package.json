{
  "name": "hrl-b2b-platform",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev:backend": "tsx backend/server.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev": "npm run dev:backend",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:backend": "esbuild backend/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build": "npm run build:frontend && npm run build:backend",
    "vercel-build": "npm run build:frontend -- --outDir=dist/client",
    "start": "node dist/server.cjs",
    "clean": "rimraf dist server.js",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx frontend/src backend/src backend/server.ts",
    "lint:fix": "eslint --ext .ts,.tsx,.js,.jsx frontend/src backend/src backend/server.ts --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:smoke": "vitest run backend/tests/smoke.test.ts",
    "test:e2e": "playwright test",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --check",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "tsx": "^4.21.0",
    "vite": "^6.2.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.38.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vitest": "^1.3.0"
  }
}
