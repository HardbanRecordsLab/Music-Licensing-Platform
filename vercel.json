{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build:frontend && cp -r frontend/dist public",
  "outputDirectory": "public",
  "build": {
    "env": {
      "VITE_API_URL": "https://hrl-sync-hub.hardbanrecordslab.online",
      "NODE_ENV": "production"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|ico|png|svg|jpg|jpeg|gif|webp|woff|woff2|ttf|eot))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
